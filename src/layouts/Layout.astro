---
import Header from './partials/Header.astro';
import '../styles/global.scss';
import Footer from './partials/Footer.astro';
import CookieBanner from './components/CookieBanner.astro';
import { ClientRouter } from 'astro:transitions';
import roboto400 from '@fontsource/roboto/files/roboto-latin-ext-400-normal.woff2?url';
import roboto500 from '@fontsource/roboto/files/roboto-latin-ext-500-normal.woff2?url';
import roboto700 from '@fontsource/roboto/files/roboto-latin-ext-700-normal.woff2?url';
import '@fontsource/roboto/latin-ext-400.css';
import '@fontsource/roboto/latin-ext-500.css';
import '@fontsource/roboto/latin-ext-700.css';

export interface Props {
  title: string;
  description: string;
  permalink: string;
  image?: string;
  robots?: string;
}

const {
  title,
  description,
  permalink,
  robots = 'index, follow',
  image = 'https://astracodelab.com/og_astracode.png',
} = Astro.props;
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta name='viewport' content='width=device-width' , initial-scale='1' />
    <link rel='icon' type='image/svg+xml' href='/favicon.ico' />
    <link rel='canonical' href={permalink} />
    <meta name='msvalidate.01' content='08A045B5065017F91DE8FBA3B76391FC' />
    <meta name='robots' content={robots} />
    <meta name='author' content='AstracodeLAB' />
    <meta name='language' content='es' />
    <meta property='og:locale' content='es_ES' />
    <meta property='og:title' content={title} />
    <meta property='og:type' content='website' />
    <meta property='og:description' content={description} />
    <meta property='og:image' content={image} />
    <meta property='og:url' content={permalink} />
    <meta property='og:site_name' content='AstracodeLAB' />
    <meta name='facebook-domain-verification' content='siis4pr1xna8mdw75uoabxrpl3t3s8' />
    <meta name='generator' content={Astro.generator} />
    <link rel='preload' href={roboto400} as='font' type='font/woff2' crossorigin />
    <link rel='preload' href={roboto500} as='font' type='font/woff2' crossorigin />
    <link rel='preload' href={roboto700} as='font' type='font/woff2' crossorigin />
    <ClientRouter />
    <script>
      function hasAnalyticsConsent() {
        return document.cookie.includes('analytics=true');
      }

      function loadExternalScript(src, callback, attributes = {}) {
        if (document.querySelector(`script[src="${src}"]`)) return;

        const script = document.createElement('script');
        script.src = src;

        Object.entries(attributes).forEach(([key, value]) => {
          if (value === true) {
            script.setAttribute(key, '');
          } else if (value) {
            script.setAttribute(key, value);
          }
        });

        if (callback) {
          script.onload = callback;
        }

        document.head.appendChild(script);
      }

      function initAnalytics() {
        if (!hasAnalyticsConsent() || window.analyticsLoaded) return;
        window.analyticsLoaded = true;

        loadExternalScript(
          'https://www.googletagmanager.com/gtag/js?id=G-ZXB197TZT1',
          () => {
            window.dataLayer = window.dataLayer || [];
            window.gtag = function () {
              dataLayer.push(arguments);
            };
            window.gtag('js', new Date());
            window.gtag('config', 'G-ZXB197TZT1');
          },
          { async: true }
        );

        loadExternalScript('https://tracker.metricool.com/resources/be.js', () => {
          if (window.beTracker) {
            window.beTracker.t({
              hash: '8b8b405910d9edbd37455a5df4a9f3aa',
            });
          }
        });
      }

      function scheduleAnalyticsLoad() {
        if (!hasAnalyticsConsent()) return;

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(initAnalytics, { timeout: 2000 });
        } else {
          window.setTimeout(initAnalytics, 1500);
        }
      }

      window.addEventListener('load', scheduleAnalyticsLoad, { once: true });
      document.addEventListener('astro:page-load', scheduleAnalyticsLoad);
    </script>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <CookieBanner />
  </body>
</html>
