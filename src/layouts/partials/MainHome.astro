---
import Layout from '../Layout.astro';
import PricingPlans from '../components/PricingPlans.astro';
import CardPregunta from '../components/Cards/CardPregunta.astro';
import imgTimeLine from '../../images/backgroundImageSectionWhy.jpg';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import TitleSecondary from '../components/Titles/TitleSecondary.astro';
import TimelineWrapper from '../components/Timeline/TimelineWrapper.astro';
import PasoProceso from '../components/Timeline/PasoProceso.astro';
import BannerImg from '../components/Banners/BannerImg.astro';
import TextContent from '../components/TextContent.astro';
import BannerCta from '../components/Banners/BannerCta.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import WorkSection from '../components/WorkSection.astro';
import FaqsSection from '../components/FaqsSection.astro';
import Contact from '../components/Contact.astro';
import landing from '../../images/landing.jpg';
import { faqs } from '../../data/faqsHome.js';
import avatar1 from '../../images/avatar1.jpg';
import avatar2 from '../../images/avatar2.jpg';
import avatar3 from '../../images/avatar3.jpg';
import RocketIllustration from '../components/RocketIllustration.astro';
import { schemaMainHome } from '../../data/schemas/main-home.js';
---

<script type='application/ld+json' set:html={JSON.stringify(schemaMainHome)} />

<main class='mainHome'>
  <Hero />
  <Services />
  <section class='timeline-section'>
    <div class='timeline-section-header'>
      <TitleSecondary text='¿Cómo lo hacemos?' />
      <p class='timeline-section-header-text'>
        Te acompañamos en cada fase, desde la primera idea hasta el lanzamiento, para que sepas qué ocurre y qué
        necesitamos de ti en cada momento.
      </p>
    </div>
    <TimelineWrapper>
      <PasoProceso
        numero='1'
        titulo='Primera reunión'
        descripcion='Conocemos tu proyecto, tus objetivos y el tipo de web que necesitas. Puedes contárnoslo por videollamada, llamada o el canal que prefieras.'
      />
      <PasoProceso
        numero='2'
        titulo='Definimos la estructura y el contenido'
        descripcion='Definimos las páginas, funcionalidades y contenidos imprescindibles. También revisamos tu mercado y las búsquedas clave para plantear una web clara y orientada al usuario.'
        alt='Mesa de oficina con portátil, taza de café y cuadernos frente a una silla vacía'
      />
      <PasoProceso
        numero='3'
        titulo='Diseñamos y desarrollamos tu web'
        descripcion='Creamos un prototipo para revisar colores, tipografía y jerarquía visual. Después convertimos el diseño en una web rápida, accesible y adaptada a todos los dispositivos.'
      />
      <PasoProceso
        numero='4'
        titulo='Lanzamiento y soporte'
        descripcionSec='Probamos rendimiento, seguridad y usabilidad; lanzamos tu web y te acompañamos 30 días para ajustes y dudas. Si quieres, también podemos ofrecerte <a class= "linkPrimary"href="/servicios/mantenimiento-web/">planes de mantenimiento continuos.</a>'
      />
    </TimelineWrapper>
  </section>

  <section class='why-choose-us-section'>
    <div class='why-choose-us-header'>
      <TitleSecondary text='¿Por qué elegir AstracodeLAB?' />
    </div>

    <BannerImg
      imagen={imgTimeLine.src}
      descripcion='En <strong>AstracodeLAB </strong>ayudamos a negocios, profesionales y proyectos creativos a convertir su presencia online en una herramienta real de confianza y captación. Reducimos la incertidumbre del proceso, te acompañamos en cada decisión y construimos una web útil, clara y preparada para generar oportunidades, no solo una página bonita.'
      alt='Imagen de diseño web'
    />

    <section class='why-choose-us-content'>
      <TextContent
        titulo='Webs Personalizadas y Estratégicas'
        descripcion='  No partimos de plantillas genéricas, sino de tus objetivos, tu marca y la forma en la que tus clientes necesitan encontrarte, entenderte y contactar contigo.'
        descripcionSec='Optimizamos y estructuramos tu contenido para SEO y configuramos un diseño responsive para que tu web se vea perfecta en cualquier dispositivo. Además, nos ocupamos de las actualizaciones y el mantenimiento para que puedas dedicar tu tiempo a lo que más valor aporta a tu negocio o a hacer crecer tu proyecto.'
      />

      <div class='why-choose-us-right-column'>
        <div class='why-choose-us-image'>
          <img
            src={landing.src}
            alt='Personas trabajando en equipo, revisando documentos y datos en una computadora portátil, simbolizando colaboración y análisis en proyectos tecnológicos.'
          />
        </div>

        <TextContent
          titulo='Acompañamiento técnico sin lenguaje complicado'
          descripcion='En Astracodelab nos gusta conectar contigo desde el primer minuto: sin tecnicismos, con una atención personalizada y aportando valor. Desde la idea hasta la entrega, te acompañamos en todo el proceso para que tengas la web profesional que tu marca merece.'
        />
      </div>
    </section>
  </section>

  <BannerCta
    titulo='¿Listo para destacar?'
    descripcion='Creamos una web a medida para que tu negocio se vea profesional, genere confianza y convierta visitas en oportunidades.'
    texto='Hablemos de tu proyecto'
    className='btnPrimaryBanner'
  />

  <TestimonialGrid
    titulo='Lo que dicen quienes ya han confiado en AstracodeLAB'
    subtitulo='Reseñas reales de clientes que han trabajado con nosotras en proyectos web.'
    testimonials={[
      {
        imagen: avatar1,
        nombre: 'Roji M',
        rating: 5,
        fecha: 'Hace 11 meses',
        testimonial:
          'Muy contenta con el trabajo de esta empresa. Les di el contacto para un familiar y ha quedado encantado. Estuvieron en todo momento en contacto, supieron plasmar sus ideas y, además, aportaron mucha creatividad al proyecto. También me dice que son encantadoras y que, desde el primer momento, ya sabía que estaba en buenas manos. Las volveré a recomendar sin duda.',
        alt: 'Avatar de usuario. Ilustración 3D de un personaje con cabello morado en coletas, chaqueta amarilla y gafas de sol en la cabeza, sobre un fondo verde.',
      },
      {
        imagen: avatar2,
        nombre: 'Helena Heras',
        rating: 5,
        testimonial:
          'Ha sido genial trabajar con el equipo AstraCodeLab. Desde el principio han mostrado una gran profesionalidad y han cumplido con todo lo acordado y plazos propuestos.Su implicación en el proyecto ha hecho obtener un diseño de la web maravilloso. Nos encanta el resultado.Sin duda cuento con ellas para futuros trabajos.',
        alt: 'Avatar de usuario. Ilustración 3D de un personaje con gorra celeste y camiseta azul, sobre un fondo verde.',
      },
      {
        imagen: avatar3,
        nombre: 'Alex N',
        rating: 5,
        fecha: 'Hace 11 meses',
        testimonial:
          'Muy satisfecho con el resultado obtenido, la web que me han diseñado funciona estupendamente y a un precio muy competitivo. El trato recibido estupendo, no se puede ser más profesional.',
        alt: 'Avatar de usuario. Ilustración 3D de un personaje con cabello pelirrojo y sudadera morada, sobre un fondo azul oscuro. ',
      },
      {
        imagen: avatar1,
        nombre: 'Thais Hidalgo',
        rating: 5,
        fecha: 'Hace 4 meses',
        testimonial:
          'Las chicas son estupendas. Atentas y profesionales. Adaptan perfectamente tus ideas a la web. 100% recomendables!!',
        alt: 'Avatar de usuario. Ilustración 3D de un personaje con cabello pelirrojo y sudadera morada, sobre un fondo azul oscuro. ',
      },
      {
        imagen: avatar3,
        nombre: 'Elisa Martin-Caro Zapardiel',
        rating: 5,
        testimonial:
          'La experiencia con Astracodelab está siendo fantástica. Acompañan tu proyecto con una gran atención, flexibilidad, disponibilidad, haciendo propuestas interesantes y buscando responder de la mejor manera a las exigencias del proyecto. El hecho de que propongan un servicio de accesibilidad web me parece algo fundamental.',
        alt: 'Avatar de usuario. Ilustración 3D de un personaje con cabello pelirrojo y sudadera morada, sobre un fondo azul oscuro. ',
      },
    ]}
  />

  <WorkSection titulo='¿Quieres ver nuestros trabajos?' />
  <section class='section-prices'>
    <div class='section-prices-header'>
      <TitleSecondary
        text='Planes claros para crear tu web profesional'
        description='Elige el punto de partida que mejor encaja con tu proyecto. Todos los planes incluyen diseño responsive, configuración inicial y soporte durante el primer mes.
'
      />
    </div>
    <PricingPlans />
    <div>
      <CardPregunta
        title='¿Tienes una idea que no encuentras en estos planes o no sabes por dónde empezar?'
        text='Cuéntanosla y te guiaremos hacia la solución perfecta para tu proyecto.'
        buttonText='¿Hablamos?'
        buttonHref='/contacto/'
      />
    </div>
  </section>
  <FaqsSection titulo='Preguntas frecuentes' faqs={faqs} />
  <Contact titulo='Contacto' />
</main>
