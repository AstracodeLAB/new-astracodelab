---
import Buttons from '../Buttons/Buttons.astro';
import '../../../styles/CardPregunta.scss';

interface Props {
  title: string;
  text: string;
  buttonText: string;
  buttonHref: string;
  buttonClass?: string;
  className?: string;
}

const {
  title,
  text,
  buttonText,
  buttonHref,
  buttonClass = "cardPregunta__cta",
  className = "",
} = Astro.props;
---

<section class={`cardPregunta ${className}`}>
  <article class="cardPregunta__content">
    <div class="cardPregunta__halo" aria-hidden="true"></div>
    <div class="cardPregunta__glyph" aria-hidden="true">?</div>
    <div class="cardPregunta__corner-glow" aria-hidden="true"></div>

    <div class="cardPregunta__inner">
      <div class="cardPregunta__text">
        <p class="cardPregunta__eyebrow">
          <span></span>
          ¿Aún con dudas?
        </p>
        <h2 class="cardPregunta__title">{title}</h2>
        <p class="cardPregunta__description">{text}</p>
      </div>

      <div class="cardPregunta__action">
        <Buttons className={buttonClass} href={buttonHref}>
          {buttonText}
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </Buttons>
      </div>
    </div>
  </article>
</section>
