---
import Layout from '../layouts/Layout.astro';
import MainHome from '../layouts/partials/MainHome.astro';

const title = 'AstracodeLAB | Agencia de Desarrollo Web en Espa\u00f1a';
const description =
  'AstracodeLAB es un estudio web con equipo en Barcelona, M\u00e1laga y Valencia. Creamos soluciones digitales, \u00e1giles y accesibles que reflejan tu marca o tu talento creativo. Ofrecemos soluciones web a medida para clientes en toda Espa\u00f1a.';
const permalink = Astro.url.href;
const robots = 'index, follow';
---

<Layout title={title} description={description} permalink={permalink} robots={robots}>
  <MainHome />
</Layout>
