---
import Layout from '../layouts/Layout.astro';
import heroImgAccesible from '../images/accesibilidad.svg';
import HeroSeo from '../layouts/components/HeroSeo.astro';
import PorqNecesitoWebSeo from '../layouts/components/PorqNecesitoWebSeo.astro';
import AdvantagesSection from '../layouts/components/AdvantagesSection.astro';
import Charge from '../layouts/components/icons/Charge.astro';
import User from '../layouts/components/icons/user.astro';
import Search from '../layouts/components/icons/search.astro';
import Comment from '../layouts/components/icons/comment.astro';
import Chart from '../layouts/components/icons/chart.astro';
import BannerCta from '../layouts/components/Banners/BannerCta.astro';
import CardPregunta from '../layouts/components/Cards/CardPregunta.astro';
import FaqsSection from '../layouts/components/FaqsSection.astro';
import LocalProjectsSection from '../layouts/components/LocalProjectsSection.astro';
import { faqsSeoMalaga } from '../layouts/components/accordeon/Faqs.js';
import { schemaLocalMalaga } from '../data/faqsSeoMalaga.js';
import alexisDesktop from '../images/mockups/scroll-alexis-desktop.webp';
import alexisTablet from '../images/mockups/scroll-alexis-tablet.webp';
import alexisMobile from '../images/mockups/scroll-alexis-mobile.webp';

const title = 'Diseño web en Málaga | AstracodeLAB';
const description = 'Páginas web en Málaga y Costa del Sol. Creamos webs profesionales para empresas y autónomos. Consulta sin compromiso.';
const permalink = Astro.url.href;
const image = 'https://astracodelab.com/og_diseño_web_desarrollo_web_malaga.png';
const robots = 'index, follow';

const localProjects = [
  {
    id: 'alexis',
    name: 'Alexis Navas',
    sector: 'Legal · Málaga',
    year: '2024',
    type: 'Web portfolio',
    url: 'alexisnavas.com',
    services: ['Diseño web', 'Astro', 'SEO'],
    desc: 'Portfolio profesional para perito judicial en tasación de obras de arte. De funcional a una web que inspira confianza.',
    img: {
      desktop: alexisDesktop.src,
      tablet: alexisTablet.src,
      mobile: alexisMobile.src,
    },
  },
];
---

<script type='application/ld+json' set:html={JSON.stringify(schemaLocalMalaga)} />

<Layout title={title} description={description} permalink={permalink} image={image} robots={robots}>
  <main class='mainHome'>
    <HeroSeo
      title='Diseño de páginas web en Málaga'
      subtitle='Diseño web en Málaga para negocios que quieren crecer online'
      text='Con equipo en Málaga, creamos webs profesionales para una de las ciudades con mayor crecimiento digital de España. Trabajamos con negocios de la Costa del Sol, empresas del Parque Tecnológico de Andalucía (PTA) y comercios del centro  histórico malagueño.'
      image={heroImgAccesible}
      alt='Ilustración de un ordenador portátil con una ventana web abierta y un botón de Click Here, acompañado de un cohete despegando.'
    />
    <PorqNecesitoWebSeo
      title='¿Por qué tu negocio en Málaga necesita una página web?'
      text='Hoy, tu cliente potencial en Málaga decide en pocos segundos si confía en una marca o la descarta, a menudo desde la pantalla de su móvil. Este veredicto se basa, casi siempre, en la primera impresión que ofrece tu sitio web. Por eso, una página web profesional para tu negocio en Málaga ya no es un lujo.'
    />
    <AdvantagesSection
      titulo='Qué ganas al elegir astracodelab como tu agencia web en Málaga'
      descripcion='Con equipo en Málaga y presencia en el Parque Tecnológico de Andalucía, combinamos creatividad mediterránea con rigor técnico. Diseñamos webs que conectan con el turista internacional y el cliente local por igual.'
      advantages={[
        {
          iconoComponent: Charge,
          titulo: 'Carga rápida',
          descripcion:
            'El turista que busca tu negocio en la Costa del Sol decide en milisegundos. Optimizamos la velocidad de tu web para captar a ese visitante impaciente que compara opciones desde su smartphone.',
        },
        {
          iconoComponent: User,
          titulo: 'Diseño centrado en el usuario',
          descripcion:
            'Málaga recibe visitantes de todo el mundo. Diseñamos interfaces multilingües e intuitivas que funcionan igual de bien para el malagueño de toda la vida que para el nómada digital recién llegado.',
        },
        {
          iconoComponent: Search,
          titulo: 'Contenido listo para buscadores',
          descripcion:
            'En una ciudad con tanta oferta como Málaga, la visibilidad en Google marca la diferencia. Trabajamos el SEO local para que tu negocio aparezca cuando un potencial cliente busca tus servicios en la zona.',
        },
        {
          iconoComponent: Chart,
          titulo: 'Proyectos escalables y adaptables',
          descripcion:
            'Desde una carta digital para tu restaurante en el centro hasta un sistema de reservas para tu hotel en la Costa, tu web se adapta a las necesidades cambiantes del mercado malagueño.',
        },
        {
          iconoComponent: Comment,
          titulo: 'Acompañamiento cercano y personalizado',
          descripcion:
            'Nuestro equipo en Málaga está disponible para reuniones presenciales y seguimiento cercano. Te acompañamos desde la idea inicial hasta mucho después del lanzamiento de tu web.',
        },
      ]}
    />

    <LocalProjectsSection
      title='Nuestros trabajos recientes en Málaga'
      description='Una muestra de proyectos reales que hemos desarrollado para profesionales y negocios de la zona.'
      projects={localProjects}
    />

    <div>
      <CardPregunta
        title='¿Tienes una idea de negocio en Málaga que no encaja en estos servicios, o no sabes por dónde empezar tu proyecto de diseño web?'
        text='Cuéntanos tu proyecto y te guiaremos hacia la solución digital perfecta para tu marca. Como tu agencia web local de Málaga, estamos listos para ayudarte.'
        buttonText='¿Hablamos?'
        buttonHref='/contacto/'
      />
    </div>
    <FaqsSection titulo='Preguntas frecuentes sobre nuestros servicios de diseño web en Málaga' faqs={faqsSeoMalaga} />
  </main>
</Layout>
