---
import Layout from '../../layouts/Layout.astro';
import '../../styles/blog.scss';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const backUrl = '/blog/';

const { post } = Astro.props;
const { Content } = await render(post);

const title = `${post.data.title} | Astracodelab`;
const description = post.data.excerpt;

const permalink = Astro.url.href;
const robots = 'index, follow';

const createSlug = (value: string) =>
  value
    .replace(/<[^>]+>/g, '')
    .replace(/[`*_~]/g, '')
    .replace(/[^\p{L}\p{N}\s-]/gu, '')
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '-');

const slugCounts = new Map<string, number>();
const tocItems = [...(post.body ?? '').matchAll(/^##\s+(.+)$/gm)].map((match) => {
  const text = match[1].replace(/\s+#*$/, '').trim();
  const baseId = createSlug(text);
  const count = slugCounts.get(baseId) ?? 0;
  slugCounts.set(baseId, count + 1);

  return {
    id: count === 0 ? baseId : `${baseId}-${count}`,
    label: text,
  };
});

const encodedPermalink = encodeURIComponent(permalink);
const encodedTitle = encodeURIComponent(post.data.title);
const shareLinks = {
  x: `https://twitter.com/intent/tweet?url=${encodedPermalink}&text=${encodedTitle}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedPermalink}`,
  link: permalink,
};
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.updatedDate?.toISOString() || post.data.date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Astracodelab',
    url: 'https://astracodelab.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Astracodelab',
    logo: {
      '@type': 'ImageObject',
      url: 'https://astracodelab.com/logo.png',
    },
  },
  image: post.data.cover.src,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': permalink,
  },
};
---

<Layout title={title} description={description} permalink={permalink} robots={robots}>
  <script type='application/ld+json' set:html={JSON.stringify(blogSchema)} />

  <main class='post-detail'>
    <div class='container-post-detail'>
      <a class='blog-back' href={backUrl}>
        <svg
          viewBox='0 0 24 24'
          width='15'
          height='15'
          fill='none'
          stroke='currentColor'
          stroke-width='2.5'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
        >
          <path d='M19 12H5M11 19l-7-7 7-7'></path>
        </svg>
        Volver al blog
      </a>

      <section class='header-post-detail'>
        <span class='blog-chip'>Guía web</span>
        <h1>{post.data.title}</h1>
        <p>{post.data.excerpt}</p>
        <div class='post-date-container'>
          <span class='date'>
            {post.data.date.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
          </span>
        </div>

        <Image
          src={post.data.cover}
          alt={post.data.coverAlt}
          class='post-detail-image'
          loading='eager'
          fetchpriority='high'
        />
      </section>

      {
        tocItems.length > 0 && (
          <nav class='post-toc post-toc--compact' aria-label='Índice de la guía'>
            <div class='post-toc__label'>Índice de la guía</div>
            <ol>
              {tocItems.map((item, index) => (
                <li>
                  <a href={`#${item.id}`}>
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    {item.label}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }

      <div class='post-layout'>
        <section class='content'>
          <div class='post-content'>
            <Content components={{ Image }} />
          </div>
        </section>

        <aside class='post-sidebar' aria-label='Contenido relacionado del artículo'>
          {
            tocItems.length > 0 && (
              <nav class='post-toc' aria-label='Índice de la guía'>
                <div class='post-toc__label'>Índice de la guía</div>
                <ol>
                  {tocItems.map((item, index) => (
                    <li>
                      <a href={`#${item.id}`}>
                        <span>{String(index + 1).padStart(2, '0')}</span>
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            )
          }

          <div class='post-share'>
            <div class='post-toc__label'>Compartir</div>
            <div class='post-share__links'>
              <a href={shareLinks.x} target='_blank' rel='noopener noreferrer' aria-label='Compartir en X'>
                <svg viewBox='0 0 24 24' width='17' height='17' fill='currentColor' aria-hidden='true'>
                  <path d='M18.9 2H22l-7.5 8.6L23 22h-6.8l-5.3-6.9L4.8 22H1.7l8-9.2L1 2h6.9l4.8 6.3L18.9 2zm-1.2 18h1.9L7.4 4H5.4l12.3 16z'></path>
                </svg>
              </a>
              <a href={shareLinks.linkedin} target='_blank' rel='noopener noreferrer' aria-label='Compartir en LinkedIn'>
                <svg viewBox='0 0 24 24' width='17' height='17' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
                  <path d='M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z'></path>
                  <rect x='2' y='9' width='4' height='12'></rect>
                  <circle cx='4' cy='4' r='2'></circle>
                </svg>
              </a>
              <a href={shareLinks.link} aria-label='Copiar enlace del artículo'>
                <svg viewBox='0 0 24 24' width='17' height='17' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
                  <path d='M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7'></path>
                  <path d='M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7'></path>
                </svg>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</Layout>

