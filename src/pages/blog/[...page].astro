---
import Layout from '../../layouts/Layout.astro';
import '../../styles/blog.scss';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('blog');
  allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return paginate(allPosts, { pageSize: 6 });
}

const { page } = Astro.props;
const postsData = page.data;
const featuredPost = postsData[0];
const restPosts = postsData.slice(1);

const title = 'Blog | Astracodelab';
const description = 'Guías técnicas, tendencias web y consejos de diseño y desarrollo web para mejorar tu presencia digital.';
const permalink = Astro.url.href;
const robots = 'index, follow';

const formatPostDate = (date: Date) =>
  date.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' });
---

<Layout title={title} description={description} permalink={permalink} robots={robots}>
  <main class='index-blog'>
    <div class='container-blog'>
      <header class='blog-header'>
        <span class='blog-eyebrow'><span class='blog-eyebrow__line'></span>Blog AstracodeLAB</span>
        <h1>Guías técnicas, tendencias web y desarrollo digital</h1>
        <p>
          Recursos claros para tomar mejores decisiones sobre diseño web, desarrollo, SEO técnico y crecimiento
          digital.
        </p>
      </header>

      {
        featuredPost && (
          <a href={`/blog/${featuredPost.id}/`} class='featured-post'>
            <div class='featured-post__media'>
              <img src={featuredPost.data.cover.src} alt={featuredPost.data.coverAlt} loading='eager' />
            </div>
            <div class='featured-post__body'>
              <div class='blog-tags'>
                <span class='blog-badge'>Destacado</span>
                <span class='blog-chip'>Guía web</span>
              </div>
              <h2>{featuredPost.data.title}</h2>
              <p>{featuredPost.data.excerpt}</p>
              <div class='blog-card-footer'>
                <span class='blog-meta' aria-label='Fecha de publicación'>
                  <svg
                    viewBox='0 0 24 24'
                    width='14'
                    height='14'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    aria-hidden='true'
                  >
                    <rect x='3' y='4' width='18' height='18' rx='2'></rect>
                    <line x1='16' y1='2' x2='16' y2='6'></line>
                    <line x1='8' y1='2' x2='8' y2='6'></line>
                    <line x1='3' y1='10' x2='21' y2='10'></line>
                  </svg>
                  {formatPostDate(featuredPost.data.date)}
                </span>
                <span class='blog-read-more'>
                  Leer más
                  <svg
                    viewBox='0 0 24 24'
                    width='15'
                    height='15'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='2.5'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    aria-hidden='true'
                  >
                    <path d='M5 12h14M13 5l7 7-7 7'></path>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        )
      }

      <section class='blog-grid' aria-label='Artículos del blog'>
        {
          restPosts.map((post) => (
            <a href={`/blog/${post.id}/`} class='post-card'>
              <div class='post-card__media'>
                <img src={post.data.cover.src} alt={post.data.coverAlt} loading='lazy' />
              </div>
              <div class='post-card__body'>
                <span class='blog-chip'>Guía web</span>
                <h2>{post.data.title}</h2>
                <p>{post.data.excerpt}</p>
                <div class='blog-card-footer'>
                  <span class='blog-meta' aria-label='Fecha de publicación'>
                    <svg
                      viewBox='0 0 24 24'
                      width='14'
                      height='14'
                      fill='none'
                      stroke='currentColor'
                      stroke-width='2'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      aria-hidden='true'
                    >
                      <rect x='3' y='4' width='18' height='18' rx='2'></rect>
                      <line x1='16' y1='2' x2='16' y2='6'></line>
                      <line x1='8' y1='2' x2='8' y2='6'></line>
                      <line x1='3' y1='10' x2='21' y2='10'></line>
                    </svg>
                    {formatPostDate(post.data.date)}
                  </span>
                  <span class='blog-read-more'>
                    Leer más
                    <svg
                      viewBox='0 0 24 24'
                      width='15'
                      height='15'
                      fill='none'
                      stroke='currentColor'
                      stroke-width='2.5'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      aria-hidden='true'
                    >
                      <path d='M5 12h14M13 5l7 7-7 7'></path>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </section>

      <section class='blog-budget-cta' aria-labelledby='blog-budget-cta-title'>
        <div class='blog-budget-cta__content'>
          <h2 id='blog-budget-cta-title'>¿Quieres un presupuesto a medida para tu proyecto?</h2>
          <p>Cuéntanos tu idea y te preparamos una propuesta adaptada a tus objetivos.</p>
        </div>
        <a href='/contacto/' class='blog-budget-cta__button'>
          Pedir presupuesto
          <svg
            viewBox='0 0 24 24'
            width='18'
            height='18'
            fill='none'
            stroke='currentColor'
            stroke-width='2.5'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
          >
            <path d='M5 12h14M13 5l7 7-7 7'></path>
          </svg>
        </a>
      </section>
      <nav class='pagination-blog' aria-label='Paginación del blog'>
        {
          page.url.prev ? (
            <a href={page.url.prev} class='pag-btn'>
              ← Anterior
            </a>
          ) : (
            <span class='disabled'>← Anterior</span>
          )
        }

        <span>
          {page.currentPage} de {page.lastPage} página
        </span>

        {
          page.url.next ? (
            <a href={page.url.next} class='pag-btn'>
              Siguiente →
            </a>
          ) : (
            <span class='disabled'>Siguiente →</span>
          )
        }
      </nav>
    </div>
  </main>
</Layout>

