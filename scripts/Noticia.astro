---
// src/pages/blog/[slug].astro  (o src/components/Noticia.astro)
//
// Página de detalle de noticia / artículo para AstracodeLAB
// Variante: CON SIDEBAR (índice de contenidos sticky + compartir)
//
// El contenido del artículo se modela como bloques (data/noticia.json -> blocks[]),
// lo que facilita renderizar desde un CMS o Markdown. En producción puedes sustituir
// el bucle de bloques por <slot /> o <Content /> de tu colección de contenido Astro.
//
// Uso:
//   ---
//   import Noticia from '@/components/Noticia.astro';
//   import data from '@/data/noticia.json';
//   ---
//   <Noticia data={data} />

interface TocItem { id: string; label: string }
interface Block {
  type: 'lead' | 'p' | 'h2' | 'h3' | 'list' | 'quote' | 'image';
  text?: string; id?: string; items?: string[]; cite?: string; src?: string; caption?: string;
}
interface Related { id: string; category: string; title: string; image: string; date: string; readTime: string }
interface NoticiaData {
  category: string; title: string; subtitle: string; cover: string; date: string; readTime: string;
  author: { name: string; role: string; avatarBg: string; avatarColor: string; initials: string };
  toc: TocItem[];
  blocks: Block[];
  tags: string[];
  cta: { title: string; subtitle: string; label: string; url: string };
  related: Related[];
}

interface Props { data: NoticiaData }
const { data } = Astro.props;
---

<article class="noticia">
  <div class="container">
    <a href="#blog" class="back">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 19l-7-7 7-7"/></svg>
      Volver al blog
    </a>

    <!-- HEADER -->
    <header class="head">
      <span class="chip">{data.category}</span>
      <h1>{data.title}</h1>
      <p class="subtitle">{data.subtitle}</p>
      <div class="head__meta">
        <div class="byline">
          <div class="avatar" style={`background:${data.author.avatarBg};color:${data.author.avatarColor};`}>{data.author.initials}</div>
          <div>
            <div class="byline__name">{data.author.name}</div>
            <div class="byline__role">{data.author.role}</div>
          </div>
        </div>
        <div class="meta">
          <span class="meta__item">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {data.date}
          </span>
          <span class="meta__dot"></span>
          <span class="meta__item">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {data.readTime} de lectura
          </span>
        </div>
      </div>
    </header>

    <!-- COVER -->
    <div class="cover" style={`background-image: url(${data.cover});`}></div>

    <!-- TOC compact (tablet/mobile) -->
    <nav class="toc toc--compact" aria-label="Tabla de contenidos">
      <div class="toc__label">En este artículo</div>
      <ol>
        {data.toc.map((t, i) => (
          <li><a href={`#${t.id}`}><span class="toc__n">{String(i + 1).padStart(2, '0')}</span>{t.label}</a></li>
        ))}
      </ol>
    </nav>

    <!-- LAYOUT -->
    <div class="layout">
      <div class="content">
        {data.blocks.map((b) => {
          if (b.type === 'lead')  return <p class="lead">{b.text}</p>;
          if (b.type === 'p')     return <p>{b.text}</p>;
          if (b.type === 'h2')    return <h2 id={b.id}>{b.text}</h2>;
          if (b.type === 'h3')    return <h3>{b.text}</h3>;
          if (b.type === 'quote') return (
            <blockquote>
              <span set:html={`&ldquo;${b.text}&rdquo;`}></span>
              {b.cite && <cite>— {b.cite}</cite>}
            </blockquote>
          );
          if (b.type === 'list')  return (
            <ul class="rich-list">
              {b.items?.map((it) => <li><span set:html={it}></span></li>)}
            </ul>
          );
          if (b.type === 'image') return (
            <figure>
              <div class="figure__img" style={`background-image: url(${b.src});`}></div>
              {b.caption && <figcaption>{b.caption}</figcaption>}
            </figure>
          );
          return null;
        })}

        <div class="tags">
          {data.tags.map((t) => <span class="tag">#{t}</span>)}
        </div>

        <!-- Inline CTA -->
        <div class="inline-cta">
          <div class="inline-cta__glow" aria-hidden="true"></div>
          <div class="inline-cta__text">
            <h3>{data.cta.title}</h3>
            <p>{data.cta.subtitle}</p>
          </div>
          <a href={data.cta.url} class="inline-cta__btn">
            {data.cta.label}
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- STICKY SIDEBAR (desktop) -->
      <aside class="sidebar">
        <nav class="toc" aria-label="Tabla de contenidos">
          <div class="toc__label">En este artículo</div>
          <ol>
            {data.toc.map((t, i) => (
              <li><a href={`#${t.id}`}><span class="toc__n">{String(i + 1).padStart(2, '0')}</span>{t.label}</a></li>
            ))}
          </ol>
        </nav>
        <div class="share-box">
          <div class="toc__label">Compartir</div>
          <div class="share">
            <a href="#" aria-label="Compartir en X"><svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M18.9 2H22l-7.5 8.6L23 22h-6.8l-5.3-6.9L4.8 22H1.7l8-9.2L1 2h6.9l4.8 6.3L18.9 2zm-1.2 18h1.9L7.4 4H5.4l12.3 16z"/></svg></a>
            <a href="#" aria-label="Compartir en LinkedIn"><svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>
            <a href="#" aria-label="Copiar enlace"><svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.5.5l3-3a5 5 0 00-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 00-7.5-.5l-3 3a5 5 0 007 7l1.7-1.7"/></svg></a>
          </div>
        </div>
      </aside>
    </div>

    <!-- RELATED -->
    <section class="related">
      <h2>Sigue leyendo</h2>
      <div class="related__grid">
        {data.related.map((r) => (
          <a href={`#${r.id}`} class="rcard">
            <div class="rcard__img" style={`background-image: url(${r.image});`}></div>
            <div class="rcard__body">
              <span class="chip">{r.category}</span>
              <h3>{r.title}</h3>
              <div class="rcard__meta">{r.date} · {r.readTime}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</article>

<style lang="scss">
  @import '../styles/variables.scss'; // Ajusta a tu ruta

  .noticia {
    font-family: $font-primary;
    background: linear-gradient(180deg, #f8f6ff 0%, #ffffff 100%);
    padding: 2.5rem 1.25rem 3.5rem;
    color: $title-color;
    @media (min-width: 768px)  { padding: 2.5rem 2rem 4rem; }
    @media (min-width: 1024px) { padding: 2.5rem 3rem 5.5rem; }
  }
  .container { max-width: 1140px; margin: 0 auto; }

  .back {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.85rem; font-weight: 600; letter-spacing: 0.02em;
    color: $blue-primary; text-decoration: none; margin-bottom: 1.5rem;
    &:hover { text-decoration: underline; }
  }

  /* header */
  .head {
    display: flex; flex-direction: column; gap: 1rem;
    margin-bottom: 1.75rem; max-width: 820px;
    h1 {
      margin: 0; font-weight: 700; letter-spacing: -0.025em; line-height: 1.06; text-wrap: balance;
      font-size: 1.85rem;
      @media (min-width: 768px)  { font-size: 2.25rem; }
      @media (min-width: 1024px) { font-size: 3rem; }
    }
    .subtitle { margin: 0; line-height: 1.5; color: $text-bg-white; text-wrap: pretty;
      font-size: 1.05rem; @media (min-width: 1024px) { font-size: 1.2rem; }
    }
    &__meta {
      display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
      padding-top: 1rem; border-top: 1px solid rgba(100,30,255,0.10);
    }
  }
  .chip {
    display: inline-block; width: fit-content; padding: 5px 13px; border-radius: 999px;
    background: $blue-secondary; color: $blue-primary;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  }
  .byline { display: inline-flex; align-items: center; gap: 0.75rem;
    &__name { font-size: 0.92rem; font-weight: 600; color: $title-color; }
    &__role { font-size: 0.78rem; color: $text-bg-white; }
  }
  .avatar {
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.95rem; flex-shrink: 0;
    box-shadow: inset 0 0 0 2px rgba(255,255,255,0.6);
  }
  .meta { display: inline-flex; align-items: center; gap: 0.625rem; font-size: 0.82rem; color: $text-bg-white;
    &__item { display: inline-flex; align-items: center; gap: 5px; }
    &__dot { width: 3px; height: 3px; border-radius: 50%; background: currentColor; opacity: 0.5; }
  }

  /* cover */
  .cover {
    border-radius: 18px; aspect-ratio: 16/9; background-size: cover; background-position: center;
    box-shadow: 0 24px 60px rgba(42,17,96,0.20); margin-bottom: 1.75rem;
    @media (min-width: 1024px) { aspect-ratio: 21/9; border-radius: 24px; margin-bottom: 2.75rem; }
  }

  /* TOC */
  .toc {
    background: #fff; border: 1px solid rgba(100,30,255,0.10); border-radius: 18px; padding: 1.375rem;
    &__label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.16em; color: $blue-primary; text-transform: uppercase; margin-bottom: 0.875rem; }
    ol { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; }
    a {
      display: flex; gap: 0.625rem; align-items: baseline;
      font-size: 0.9rem; line-height: 1.4; color: $text-bg-color; text-decoration: none;
      &:hover { color: $blue-primary; }
    }
    &__n { font-family: monospace; font-size: 0.78rem; font-weight: 700; color: $blue-primary; flex-shrink: 0; }
    &--compact { background: $blue-secondary; margin-bottom: 1.75rem;
      @media (min-width: 1024px) { display: none; }
    }
  }

  /* layout */
  .layout {
    display: grid; grid-template-columns: 1fr; gap: 0;
    @media (min-width: 1024px) { grid-template-columns: 1fr 280px; gap: 3.5rem; align-items: start; }
  }
  .content {
    max-width: 740px; min-width: 0;
    display: flex; flex-direction: column; gap: 1.125rem;
    @media (min-width: 1024px) { gap: 1.375rem; }

    p { margin: 0; line-height: 1.7; color: $text-bg-color; text-wrap: pretty;
      font-size: 1rem; @media (min-width: 1024px) { font-size: 1.075rem; }
    }
    .lead { font-weight: 500; color: $title-color; letter-spacing: -0.005em; line-height: 1.5;
      font-size: 1.2rem; @media (min-width: 1024px) { font-size: 1.3rem; }
    }
    h2 { margin: 0.5rem 0 0; font-weight: 700; color: $title-color; letter-spacing: -0.018em; line-height: 1.18; text-wrap: balance; scroll-margin-top: 90px;
      font-size: 1.5rem; @media (min-width: 1024px) { font-size: 1.75rem; }
    }
    h3 { margin: 0.25rem 0 0; font-weight: 700; color: $blue-primary; letter-spacing: -0.01em; line-height: 1.25;
      font-size: 1.15rem; @media (min-width: 1024px) { font-size: 1.3rem; }
    }
  }
  .rich-list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.75rem;
    li { display: flex; gap: 0.75rem; align-items: flex-start; line-height: 1.6; color: $text-bg-color;
      font-size: 1rem; @media (min-width: 1024px) { font-size: 1.05rem; }
      &::before { content: ''; flex-shrink: 0; margin-top: 0.5rem; width: 7px; height: 7px; border-radius: 50%; background: $blue-primary; }
    }
    :global(strong) { color: $title-color; font-weight: 600; }
  }
  blockquote {
    margin: 0.5rem 0; padding: 0.5rem 0 0.5rem 1.75rem;
    border-left: 3px solid $blue-primary;
    font-weight: 500; font-style: italic; color: $title-color; letter-spacing: -0.01em; line-height: 1.4;
    font-size: 1.2rem; @media (min-width: 1024px) { font-size: 1.35rem; }
    cite { display: block; margin-top: 0.625rem; font-size: 0.85rem; font-style: normal; font-weight: 600; color: $blue-primary; letter-spacing: 0.04em; }
  }
  figure { margin: 0.5rem 0;
    .figure__img { border-radius: 16px; aspect-ratio: 16/9; background-size: cover; background-position: center; box-shadow: 0 12px 36px rgba(42,17,96,0.16); }
    figcaption { margin-top: 0.625rem; font-size: 0.82rem; color: $text-bg-white; text-align: center; font-style: italic; }
  }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 2rem 0; padding-top: 1.5rem; border-top: 1px solid rgba(100,30,255,0.10);
    @media (min-width: 1024px) { margin: 2.75rem 0; }
  }
  .tag { padding: 7px 14px; border-radius: 999px; background: $blue-secondary; color: $blue-primary; font-size: 0.82rem; font-weight: 600; }

  /* inline CTA */
  .inline-cta {
    position: relative; overflow: hidden;
    background: $gradientButton; border-radius: 22px; color: #fff;
    padding: 1.75rem 1.5rem; box-shadow: 0 20px 50px rgba(100,30,255,0.30);
    display: flex; flex-direction: column; align-items: flex-start; gap: 1.25rem;
    @media (min-width: 768px) { flex-direction: row; align-items: center; justify-content: space-between; padding: 2.25rem 2.5rem; }
    &__glow { position: absolute; top: -40px; right: -30px; width: 180px; height: 180px; border-radius: 50%; background: radial-gradient(circle, rgba(187,255,0,0.18) 0%, transparent 70%); }
    &__text { position: relative; max-width: 540px;
      h3 { margin: 0 0 0.5rem; font-weight: 700; letter-spacing: -0.015em; line-height: 1.2; text-wrap: balance;
        font-size: 1.2rem; @media (min-width: 1024px) { font-size: 1.5rem; }
      }
      p { margin: 0; font-size: 0.95rem; line-height: 1.5; color: rgba(255,255,255,0.82); text-wrap: pretty; }
    }
    &__btn {
      position: relative; flex-shrink: 0;
      display: inline-flex; align-items: center; gap: 0.625rem;
      padding: 0.875rem 1.625rem; border-radius: 999px;
      background: $green; color: $blue-dark; font-size: 0.95rem; font-weight: 700; letter-spacing: 0.03em;
      text-decoration: none; box-shadow: 0 8px 24px rgba(187,255,0,0.30); transition: transform 0.2s;
      &:hover { transform: translateY(-2px); }
    }
  }

  /* sidebar */
  .sidebar { display: none;
    @media (min-width: 1024px) { display: flex; flex-direction: column; gap: 1.125rem; position: sticky; top: 2rem; }
  }
  .share-box { background: #fff; border: 1px solid rgba(100,30,255,0.10); border-radius: 18px; padding: 1.375rem; display: flex; flex-direction: column; gap: 0.875rem; }
  .share { display: flex; gap: 0.625rem;
    a { display: inline-flex; align-items: center; justify-content: center; width: 42px; height: 42px; border-radius: 50%; background: $blue-secondary; color: $blue-primary; text-decoration: none; transition: transform 0.2s, background 0.2s, color 0.2s;
      &:hover { transform: translateY(-2px); background: $gradientButton; color: #fff; }
    }
  }

  /* related */
  .related { margin-top: 3rem;
    @media (min-width: 1024px) { margin-top: 4.5rem; }
    > h2 { margin: 0 0 1.5rem; font-weight: 700; color: $title-color; letter-spacing: -0.015em;
      font-size: 1.4rem; @media (min-width: 1024px) { font-size: 1.75rem; }
    }
    &__grid { display: grid; grid-template-columns: 1fr; gap: 1rem;
      @media (min-width: 640px) { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    }
  }
  .rcard {
    display: flex; flex-direction: column; text-decoration: none;
    background: #fff; border-radius: 18px; overflow: hidden;
    border: 1px solid rgba(100,30,255,0.07); box-shadow: 0 1px 20px rgba(42,17,96,0.06);
    transition: transform 0.25s, box-shadow 0.25s;
    &:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(42,17,96,0.14); }
    &__img { aspect-ratio: 16/10; background-size: cover; background-position: center; }
    &__body { padding: 1.125rem; display: flex; flex-direction: column; gap: 0.625rem;
      h3 { margin: 0; font-size: 1.02rem; font-weight: 700; color: $title-color; line-height: 1.25; letter-spacing: -0.005em; text-wrap: balance; }
    }
    &__meta { font-size: 0.76rem; color: $text-bg-white; letter-spacing: 0.02em; }
  }
</style>
