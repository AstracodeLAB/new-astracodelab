---
// src/components/Blog.astro
//
// Sección de Blog para AstracodeLAB
// Variante: FEATURED + GRID (artículo destacado + grid con metadata)
//
// Uso:
//   ---
//   import Blog from '@/components/Blog.astro';
//   import blogData from '@/data/blog.json';
//   ---
//   <Blog data={blogData} />

interface Post {
  id: string;
  category: string;
  title: string;
  excerpt: string;
  image: string;
  date: string;
  readTime: string;
  featured?: boolean;
}

interface BlogData {
  eyebrow: string;
  title: string;
  subtitle: string;
  posts: Post[];
  cta: string;
  viewAll: string;
}

interface Props {
  data: BlogData;
}

const { data } = Astro.props;

const featured = data.posts.find((p) => p.featured) ?? data.posts[0];
const rest = data.posts.filter((p) => p !== featured);
---

<section class="astra-blog">
  <div class="container">
    <header class="header">
      <span class="eyebrow"><span class="eyebrow__line"></span>{data.eyebrow}</span>
      <h2>{data.title}</h2>
      <p class="subtitle">{data.subtitle}</p>
    </header>

    <!-- Featured -->
    <a href={`#${featured.id}`} class="featured">
      <div class="featured__media" style={`background-image: url(${featured.image});`}></div>
      <div class="featured__body">
        <div class="tags">
          <span class="badge badge--lime">★ Destacado</span>
          <span class="chip chip--light">{featured.category}</span>
        </div>
        <h3>{featured.title}</h3>
        <p>{featured.excerpt}</p>
        <div class="meta-row">
          <div class="meta meta--light">
            <span class="meta__item">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {featured.date}
            </span>
            <span class="meta__dot"></span>
            <span class="meta__item">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {featured.readTime} lectura
            </span>
          </div>
          <span class="read-more read-more--lime">
            {data.cta}
            <svg class="bl-arrow" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </div>
      </div>
    </a>

    <!-- Grid -->
    <div class="grid">
      {rest.map((post) => (
        <a href={`#${post.id}`} class="card">
          <div class="card__media"><div class="card__img" style={`background-image: url(${post.image});`}></div></div>
          <div class="card__body">
            <span class="chip">{post.category}</span>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
            <div class="meta-row">
              <div class="meta">
                <span class="meta__item">
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {post.date}
                </span>
                <span class="meta__dot"></span>
                <span class="meta__item">{post.readTime}</span>
              </div>
              <span class="read-more">
                {data.cta}
                <svg class="bl-arrow" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="actions">
      <a href="#blog" class="view-all">
        {data.viewAll}
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style lang="scss">
  @import '../styles/variables.scss'; // Ajusta a tu ruta

  .astra-blog {
    padding: 3.5rem 1.25rem;
    background: linear-gradient(180deg, #f8f6ff 0%, #ffffff 100%);
    font-family: $font-primary;
    color: $title-color;

    @media (min-width: 768px)  { padding: 4.5rem 2rem; }
    @media (min-width: 1024px) { padding: 5.5rem 3rem; }
  }
  .container { max-width: 1200px; margin: 0 auto; }

  /* header */
  .header {
    max-width: 720px;
    margin-bottom: 2.25rem;
    @media (min-width: 1024px) { margin-bottom: 3rem; }
    h2 {
      margin: 0 0 0.75rem;
      font-size: 1.85rem; line-height: 1.06; font-weight: 700;
      color: $title-color; letter-spacing: -0.02em; text-wrap: balance;
      @media (min-width: 768px)  { font-size: 2.25rem; }
      @media (min-width: 1024px) { font-size: 2.75rem; }
    }
    .subtitle {
      margin: 0; font-weight: 500; line-height: 1.5;
      color: $text-bg-white; text-wrap: pretty;
      font-size: 1rem;
      @media (min-width: 1024px) { font-size: 1.15rem; }
    }
  }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 0.625rem;
    color: $blue-primary; font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.22em; margin-bottom: 1rem;
    &__line { width: 24px; height: 1.5px; background: $blue-primary; display: inline-block; }
  }

  /* shared chips / badges / meta */
  .tags { display: inline-flex; gap: 0.5rem; flex-wrap: wrap; }
  .badge {
    display: inline-block; padding: 5px 12px; border-radius: 999px;
    font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    &--lime { background: $green; color: $blue-dark; }
  }
  .chip {
    display: inline-block; padding: 5px 12px; border-radius: 999px;
    background: $blue-secondary; color: $blue-primary;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    &--light { background: rgba(187,255,0,0.18); color: $green; border: 1px solid rgba(187,255,0,0.30); }
  }
  .meta {
    display: inline-flex; align-items: center; gap: 0.625rem;
    font-size: 0.78rem; color: $text-bg-white; letter-spacing: 0.02em;
    &--light { color: rgba(255,255,255,0.7); }
    &__item { display: inline-flex; align-items: center; gap: 5px; }
    &__dot { width: 3px; height: 3px; border-radius: 50%; background: currentColor; opacity: 0.5; }
  }
  .meta-row { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
  .read-more {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.9rem; font-weight: 600; color: $blue-primary; letter-spacing: 0.02em;
    .bl-arrow { transition: transform 0.2s; }
    &--lime { color: $green; }
  }

  /* featured */
  .featured {
    display: grid; grid-template-columns: 1fr; text-decoration: none;
    background: $blue-dark; border-radius: 22px; overflow: hidden;
    box-shadow: 0 20px 60px rgba(30,14,98,0.30);
    transition: transform 0.3s, box-shadow 0.3s;
    @media (min-width: 768px) { grid-template-columns: 1.1fr 1fr; min-height: 360px; border-radius: 28px; }

    &:hover { transform: translateY(-4px); box-shadow: 0 30px 70px rgba(30,14,98,0.40); }
    &:hover .featured__media { transform: scale(1.05); }
    &:hover .bl-arrow { transform: translateX(4px); }

    &__media {
      background-size: cover; background-position: center;
      min-height: 220px; transition: transform 0.5s ease;
      @media (min-width: 768px) { order: 1; min-height: 100%; }
    }
    &__body {
      padding: 1.625rem 1.375rem; color: #fff;
      display: flex; flex-direction: column; gap: 1rem; justify-content: center;
      @media (min-width: 768px)  { padding: 2rem 1.75rem; }
      @media (min-width: 1024px) { padding: 2.75rem; }

      h3 {
        margin: 0; font-weight: 700; line-height: 1.12; letter-spacing: -0.02em; text-wrap: balance;
        font-size: 1.4rem;
        @media (min-width: 768px)  { font-size: 1.6rem; }
        @media (min-width: 1024px) { font-size: 2rem; }
      }
      p { margin: 0; color: rgba(255,255,255,0.78); line-height: 1.6; text-wrap: pretty;
        font-size: 0.92rem;
        @media (min-width: 1024px) { font-size: 1rem; }
      }
    }
  }

  /* grid */
  .grid {
    margin-top: 1.25rem;
    display: grid; grid-template-columns: 1fr; gap: 1.125rem;
    @media (min-width: 768px)  { grid-template-columns: 1fr 1fr; }
    @media (min-width: 1024px) { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 1.75rem; }
  }
  .card {
    display: flex; flex-direction: column; text-decoration: none;
    background: #fff; border-radius: 20px; overflow: hidden;
    border: 1px solid rgba(100,30,255,0.07);
    box-shadow: 0 1px 24px rgba(42,17,96,0.07);
    transition: transform 0.25s, box-shadow 0.25s;

    &:hover { transform: translateY(-5px); box-shadow: 0 18px 50px rgba(42,17,96,0.16); }
    &:hover .card__img { transform: scale(1.06); }
    &:hover .bl-arrow { transform: translateX(4px); }

    &__media { overflow: hidden; aspect-ratio: 16/10; }
    &__img { width: 100%; height: 100%; background-size: cover; background-position: center; transition: transform 0.4s ease; }
    &__body {
      padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; flex: 1;
      @media (min-width: 1024px) { padding: 1.5rem; }
      h3 {
        margin: 0; font-weight: 700; color: $title-color;
        line-height: 1.25; letter-spacing: -0.01em; text-wrap: balance;
        font-size: 1.08rem;
        @media (min-width: 1024px) { font-size: 1.2rem; }
      }
      p {
        margin: 0; font-size: 0.9rem; line-height: 1.6; color: $text-bg-color; text-wrap: pretty;
        display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
      }
      .meta-row {
        margin-top: auto; padding-top: 0.875rem;
        border-top: 1px solid rgba(100,30,255,0.08);
      }
    }
  }

  /* actions */
  .actions { display: flex; justify-content: center; margin-top: 2.25rem;
    @media (min-width: 1024px) { margin-top: 3rem; }
  }
  .view-all {
    display: inline-flex; align-items: center; gap: 0.625rem;
    padding: 0.875rem 1.75rem; border-radius: 999px;
    background: transparent; border: 1.5px solid rgba(100,30,255,0.3);
    color: $blue-primary; font-size: 0.95rem; font-weight: 600; letter-spacing: 0.03em;
    text-decoration: none; transition: background 0.2s, border-color 0.2s;
    &:hover { background: $blue-secondary; border-color: $blue-primary; }
  }
</style>
